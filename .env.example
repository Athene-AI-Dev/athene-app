# ── Identity (Clerk) ────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Required for Clerk testing SDK in E2E tests
CLERK_WEBHOOK_SECRET=

# ── Database (Supabase) ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection string — required by LangGraph checkpoint-postgres.
# Without this, every graph.invoke() call fails. Use the Supabase "Transaction" pooler URL.
# Format: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=
# Some LangGraph versions read SUPABASE_DB_URL — set both to the same value.
SUPABASE_DB_URL=

# ── Encryption ───────────────────────────────────────────────────────────────
# Master key for per-org KMS derivation (HMAC-SHA256). REQUIRED — throws on missing.
# Generate with: openssl rand -hex 32
KMS_KEY=

# ── App URL ──────────────────────────────────────────────────────────────────
# Public base URL — required for all QStash background job dispatches
# (indexing, graph-build, briefing). Without this, background workers cannot be dispatched.
# Local: http://localhost:3000  |  Production: https://your-domain.com
NEXT_PUBLIC_APP_URL=

# ── Nango (OAuth / integration connections) ──────────────────────────────────
NANGO_SECRET_KEY=

# ── QStash (background job queue) ────────────────────────────────────────────
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# ── Redis (Upstash) ──────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── LLM Providers ────────────────────────────────────────────────────────────
# At least one of ANTHROPIC_API_KEY or OPENAI_API_KEY is required for the agent to run.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
# Optional additional providers (LLM factory fallback chain)
DEEPSEEK_API_KEY=
TOGETHER_API_KEY=
NOMIC_API_KEY=

# ── Embedding (optional) ─────────────────────────────────────────────────────
# Jina AI for high-quality embeddings. Falls back to OpenAI / Together / local Xenova if absent.
JINA_API_KEY=

# ── OpenTelemetry (optional) ─────────────────────────────────────────────────
# Set to enable traces + metrics export to any OTLP-compatible backend.
OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
# OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=

# ── Development / Testing ────────────────────────────────────────────────────
# Secret for the /api/test/pipeline dev-only endpoint.
# If unset, the endpoint returns 404 in all environments.
TEST_PIPELINE_SECRET=
# E2E test user credentials (set in CI secrets)
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
E2E_MEMBER_EMAIL=
E2E_MEMBER_PASSWORD=
E2E_BI_EMAIL=
E2E_BI_PASSWORD=
E2E_CLERK_OTP=
