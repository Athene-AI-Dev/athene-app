{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus / Grafana Cloud Metrics",
      "description": "OTLP metrics data source",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Athene AI Agent Platform — operational metrics dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Agent Run Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(athene_agent_run_duration_ms_bucket[5m])) by (le, model))",
          "legendFormat": "p50 {{model}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(athene_agent_run_duration_ms_bucket[5m])) by (le, model))",
          "legendFormat": "p95 {{model}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(athene_agent_run_duration_ms_bucket[5m])) by (le, model))",
          "legendFormat": "p99 {{model}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 2,
      "title": "Agent Error Rate by Node",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(athene_agent_run_error_total[5m])) by (node_name, error_type)",
          "legendFormat": "{{node_name}} / {{error_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      },
      "alert": {
        "name": "High Agent Error Rate",
        "message": "Agent error rate exceeds 5% for 5 minutes",
        "conditions": [
          {
            "evaluator": { "params": [0.05], "type": "gt" },
            "operator": { "type": "and" },
            "query": { "params": ["A", "5m", "now"] },
            "reducer": { "params": [], "type": "avg" },
            "type": "query"
          }
        ]
      }
    },
    {
      "id": 3,
      "title": "HITL Approval Queue Depth (Pending)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(athene_hitl_approval_pending_duration_ms_count) - sum(athene_hitl_decision_total)",
          "legendFormat": "Pending approvals",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "HITL Decision Breakdown (Approve / Edit / Reject)",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(athene_hitl_decision_total[10m])) by (decision, tool)",
          "legendFormat": "{{decision}} / {{tool}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 5,
      "title": "Indexing Throughput by Provider",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(athene_indexer_doc_count_total[5m])) by (integration_type)",
          "legendFormat": "{{integration_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 6,
      "title": "Active Orgs (Last 24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "count(count by (org_id) (increase(athene_indexer_doc_count_total[24h])))",
          "legendFormat": "Active orgs",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 7,
      "title": "HITL Avg Pending Duration by Tool",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(athene_hitl_approval_pending_duration_ms_sum[1h])) by (tool) / sum(rate(athene_hitl_approval_pending_duration_ms_count[1h])) by (tool)",
          "legendFormat": "{{tool}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3600000 },
              { "color": "red", "value": 86400000 }
            ]
          }
        }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["athene", "ai-agents", "production"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Athene AI — Agent Platform",
  "uid": "athene-agent-platform",
  "version": 1
}
